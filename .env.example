# scitex-writer environment variables
#
# `cp .env.example .env` and edit. Loaded automatically when the package
# initializes; explicit kwargs/CLI flags still take precedence.

# SCITEX_WRITER_ALIAS=
# SCITEX_WRITER_BRAND=
# SCITEX_WRITER_ENGINE=
# SCITEX_WRITER_GUIDELINE_=
# SCITEX_WRITER_GUIDELINE_ABSTRACT=
# SCITEX_WRITER_GUIDELINE_DIR=
# SCITEX_WRITER_PROMPT_ASTA_=
# SCITEX_WRITER_PROMPT_ASTA_COAUTHORS=
# SCITEX_WRITER_PROMPT_ASTA_RELATED=
# SCITEX_WRITER_PROMPT_DIR=
# SCITEX_WRITER_ROOT=
